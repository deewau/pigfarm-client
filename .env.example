# Порт сервера
PORT=3000

# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Bot Username (без @)
TELEGRAM_BOT_USERNAME=your_bot_username_here

# Секрет для валидации initData (опционально, можно не менять)
TELEGRAM_INIT_DATA_SECRET=

# URL для webhook Telegram (должен быть публичный URL с HTTPS)
# Для Render: https://pigfarm-client.onrender.com/api/webhook
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/webhook

# URL клиента (для CORS)
CLIENT_URL=http://localhost:5173

# Режим (development / production)
NODE_ENV=development
